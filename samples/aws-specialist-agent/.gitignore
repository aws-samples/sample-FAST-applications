# GitLab Pages build output at the repo root only — a bare "public/" would
# also swallow frontend/public/ (favicon and other static assets).
/public/
.mkdocs/public/

# ASH (Automated Security Helper) scan output. The config (.ash/ash.yaml) is
# tracked; the generated reports under .ash/ash_output/ are not.
.ash/ash_output/

# Personal notes & secrets
# `_secrets/` contains CDK Outputs with account IDs / resource ARNs that
# should not be committed. Memo files with operational state live here.
docs/personal/_secrets/
# `RESUME.md` is a per-conversation work-resumption note (paste-into-prompt
# reminder). It is intentionally not committed.
docs/personal/RESUME.md

# Per-user Cedar ABAC verification scripts. These embed personal demo-user
# email addresses and a hardcoded User Pool ID, so they are
# kept local and never committed.
test-scripts/test-per-user-abac.py
test-scripts/manage-cedar-test-users.py

# Alternate deployment configs (e.g. a personal dev environment). These embed a
# real admin_user_email and environment-specific values, so they are kept local.
# The production config (infra-cdk/config.yaml) is tracked; per-environment
# overrides live in CONFIG_FILE-selected siblings like config.dev.yaml.
infra-cdk/config.dev*.yaml

# fast-project-guide build output (generated by scripts/build-project-guide.py)
skills/aws-specialist-agent/build/

# Claude Code plan-mode scratch files
plans/
