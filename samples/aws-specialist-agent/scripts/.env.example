# Settings for the demo Cognito user script (create-demo-users.py).
# Copy this file to scripts/.env and fill in real values. scripts/.env is
# git-ignored, so secrets and PII never get committed.
#
# DEMO_PASSWORD and DEMO_EMAIL_* are secrets / PII; DEMO_STACK_NAME is the
# environment to target. The User Pool / Client IDs are NOT set here -- the
# script resolves them from the named stack's CloudFormation outputs.

DEMO_EMAIL_PREFIX=your-alias    # local-part before "+role-no" (e.g. your-alias -> your-alias+finance-1@...)
DEMO_EMAIL_DOMAIN=example.com   # email domain (e.g. mycompany.com)
DEMO_PASSWORD=ChangeMe!2026     # shared password; must satisfy the pool policy (>=8 chars, upper+lower+digit+symbol)
DEMO_STACK_NAME=fast-aws-specialist # CloudFormation stack whose Cognito pool is targeted
